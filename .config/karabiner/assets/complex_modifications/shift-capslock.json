{
  "title": "Shift + CapsLock mappings",
  "rules": [
    {
      "description": "left_shift+caps_lock to page_down, right_shift+caps_lock to mission_control",
      "manipulators": [
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": { "mandatory": ["left_shift"], "optional": ["any"] }
          },
          "to": [{ "key_code": "page_down", "modifiers": [] }]
        },
        {
          "type": "basic",
          "from": {
            "key_code": "caps_lock",
            "modifiers": { "mandatory": ["right_shift"], "optional": ["any"] }
          },
          "to": [{ "apple_vendor_keyboard_key_code": "mission_control", "modifiers": ["left_command"] }]
        }
      ]
    }
  ]
}
