{
  "title": "Escape + Eisuu for Vim",
  "rules": [
    {
      "description": "escキーを押したときに、英数キーも送信する（vim用）",
      "manipulators": [
        {
          "type": "basic",
          "from": { "key_code": "escape" },
          "to": [
            { "key_code": "escape" },
            { "key_code": "japanese_eisuu" }
          ]
        }
      ]
    }
  ]
}
