#!/bin/bash
cd "$(dirname "${0}")/../" || exit

echo "Link files"
ln -sf "$PWD/.config" ~
ln -sf "$PWD/.gitconfig" ~
ln -sf "$PWD/.sshrc" ~
ln -sf "$PWD/.vimrc" ~

# SwiftBar
SWIFTBAR_PLUGIN_DIR="$HOME/Library/Application Support/SwiftBar/Plugins"
mkdir -p "$SWIFTBAR_PLUGIN_DIR"
for plugin in "$PWD"/swiftbar/plugins/*.sh; do
  [ -f "$plugin" ] && ln -sf "$plugin" "$SWIFTBAR_PLUGIN_DIR/"
done

# Claude Code
ln -sf "$PWD/bin/claude-status-hook" /opt/homebrew/bin/claude-status-hook
mkdir -p ~/.claude/rules
ln -sf "$PWD/.config/claude/settings.json" ~/.claude/settings.json
ln -sf "$PWD/.config/claude/keybindings.json" ~/.claude/keybindings.json
ln -sf "$PWD/.config/claude/CLAUDE.md" ~/.claude/CLAUDE.md
for rule in "$PWD"/.config/claude/rules/*.md; do
  [ -f "$rule" ] && ln -sf "$rule" ~/.claude/rules/
done

# Git user setting
if [ ! -e "$PWD/.config/git/user_setting" ]; then
  read -rp "Git user name: " git_name
  read -rp "Git email: " git_email
  cat > "$PWD/.config/git/user_setting" <<GITEOF
[user]
    name = ${git_name}
    email = ${git_email}
GITEOF
  echo "Created .config/git/user_setting"
fi

if [ ! -e ~/.local/share/fish/config.fish ]; then
  echo " Create ~/.local/share/fish/config.fish"

  mkdir -p ~/.local/share/fish
  echo "set -x DOTFILES_PATH $DOTFILES_PATH" >> ~/.local/share/fish/config.fish
fi
