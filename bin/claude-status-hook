#!/bin/bash
set -euo pipefail
#
# claude-status-hook - Write per-session Claude Code status
#
# Usage:
#   echo '{"session_id":"...","cwd":"..."}' | claude-status-hook <thinking|waiting|paused|cleanup>

STATUS_DIR="/tmp/claude-code-sessions"
STATUS="${1:-}"

INPUT=$(cat)
eval "$(/usr/bin/jq -r '@sh "SESSION_ID=\(.session_id // "") CWD=\(.cwd // "")"' <<< "$INPUT")"

[ -z "$SESSION_ID" ] && exit 0

mkdir -p "$STATUS_DIR"

PREV_STATUS=""
[ -f "$STATUS_DIR/$SESSION_ID" ] && PREV_STATUS=$(/usr/bin/jq -r '.status // ""' "$STATUS_DIR/$SESSION_ID" 2>/dev/null)

if [ "$STATUS" = "cleanup" ]; then
    rm -f "$STATUS_DIR/$SESSION_ID"
else
    BRANCH=$(git -C "$CWD" branch --show-current 2>/dev/null || true)
    DIR_NAME="${CWD##*/}"
    /usr/bin/jq -n --arg status "$STATUS" --arg cwd "$CWD" --arg iterm_session "${ITERM_SESSION_ID:-}" --arg branch "$BRANCH" \
        '{status: $status, cwd: $cwd, iterm_session_id: $iterm_session, branch: $branch}' > "$STATUS_DIR/$SESSION_ID"

    if [ "$PREV_STATUS" = "thinking" ] && [ "$STATUS" = "waiting" -o "$STATUS" = "paused" ]; then
        TITLE="Claude Code"
        [ "$STATUS" = "paused" ] && MSG="${DIR_NAME}: Á¢∫Ë™çÂæÖ„Å°„Åß„Åô" || MSG="${DIR_NAME}: ÂÆå‰∫Ü„Åó„Åæ„Åó„Åü"
        (result=$(alerter --title "$TITLE" --message "$MSG" --actions "Èñã„Åè" --close-label "Èñâ„Åò„Çã" --sound default --timeout 10 2>/dev/null)
        [ "$result" = "Èñã„Åè" ] && open -a Ghostty) &
    fi
fi
