#!/bin/bash
set -euo pipefail
#
# claude-status-hook - Write per-session Claude Code status
#
# Usage:
#   echo '{"session_id":"...","cwd":"..."}' | claude-status-hook <thinking|waiting|paused|cleanup>

STATUS_DIR="/tmp/claude-code-sessions"
STATUS="${1:-}"

INPUT=$(cat)
eval "$(/usr/bin/jq -r '@sh "SESSION_ID=\(.session_id // "") CWD=\(.cwd // "")"' <<< "$INPUT")"

[ -z "$SESSION_ID" ] && exit 0

mkdir -p "$STATUS_DIR"

PREV_STATUS=""
[ -f "$STATUS_DIR/$SESSION_ID" ] && PREV_STATUS=$(/usr/bin/jq -r '.status // ""' "$STATUS_DIR/$SESSION_ID" 2>/dev/null)

if [ "$STATUS" = "cleanup" ]; then
    rm -f "$STATUS_DIR/$SESSION_ID"
else
    BRANCH=$(git -C "$CWD" branch --show-current 2>/dev/null || true)
    DIR_NAME="${CWD##*/}"
    /usr/bin/jq -n --arg status "$STATUS" --arg cwd "$CWD" --arg iterm_session "${ITERM_SESSION_ID:-}" --arg branch "$BRANCH" \
        '{status: $status, cwd: $cwd, iterm_session_id: $iterm_session, branch: $branch}' > "$STATUS_DIR/$SESSION_ID"

    SHOULD_NOTIFY=false
    if [ "$STATUS" = "waiting" ] && [ "$PREV_STATUS" = "thinking" -o "$PREV_STATUS" = "paused" ]; then
        SHOULD_NOTIFY=true
    elif [ "$STATUS" = "paused" ] && [ "$PREV_STATUS" = "thinking" ]; then
        SHOULD_NOTIFY=true
    fi

    FRONTMOST=$(osascript -e 'tell application "System Events" to get name of first application process whose frontmost is true' 2>/dev/null)
    [ "$FRONTMOST" = "Ghostty" ] && SHOULD_NOTIFY=false

    if [ "$SHOULD_NOTIFY" = true ]; then
        TITLE="Claude Code"
        [ "$STATUS" = "paused" ] && MSG="${DIR_NAME}: 確認待ちです" || MSG="${DIR_NAME}: 完了しました"
        nohup bash -c "result=\$(alerter --title '$TITLE' --message '$MSG' --close-label '閉じる' --sound default --timeout 10 --ignore-dnd 2>/dev/null); [ \"\$result\" = '@CONTENTCLICKED' ] && open -a Ghostty" >/dev/null 2>&1 &
        disown
    fi
fi
